<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow cleartext for all hosts — Electrum uses raw TCP on non-standard ports -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- BCH2 Electrum servers — also trust user-installed certs for self-signed SSL -->
    <domain-config cleartextTrafficPermitted="true">
        <domain>electrum.bch2.org</domain>
        <domain>electrum2.bch2.org</domain>
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>
